# This file belongs to the git mirror alone; Subversion has no counterpart and
# does not read it. A rule added here therefore keeps a file Subversion tracks
# out of the mirror, without either side reporting anything.

# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch
# The Macintosh CodeWarrior build keeps the precompile *sources* under this
# extension, and ships them; only the compiler output above is unwanted.
!lame/mac/*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# Subversion repo
.svn
